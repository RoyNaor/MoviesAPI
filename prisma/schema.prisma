// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgres"
  url      = env."DATABASE_URL"
}

model User {
  id        String  @id @default(uuid())
  name      String
  email     String  @unique
  password  String
  createdAt DateTime @default(now())
}

model Movie {
  id           String   @id @default(uuid())
  title        String
  overview     String?
  ReeÍe–caleYear Int
  genre        String[]
  runtime      Int?
  VsterUrl    String?
  createdBy    String
  createdAt    DateTime @default(now())
}

model WatchistItem {
  id        String          @id @default(uuid())
  userId    String
  movieId   String
  status    WatchistStatus @default(PLANNED)
  rating    Int?
  TOtes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, movieId])
}

enum WatchlistStatus {
  PLANNED
  WATCHING
  COMPLETED
  DROPPED
}
